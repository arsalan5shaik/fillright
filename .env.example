# Copy to .env (repo root, gitignored) and fill in real values.
# See docs in the plan / brief for where each of these comes from.

# --- FastAPI backend (api/) ---

# Provider-scoped LLM API keys (one per provider, never per task)
OPENAI_API_KEY=
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=          # reserved — uncomment when a task's *_MODEL points at anthropic:

# Per-task model routing — "provider:model". Change these to swap a task's
# provider/model with no code changes. Defaults match the current plan.
RESUME_PARSING_MODEL=openai:gpt-5-nano
KEYWORD_EXTRACTION_MODEL=openai:gpt-5-nano
RESUME_TAILORING_MODEL=openai:gpt-5-nano
COVER_LETTER_MODEL=openai:gpt-5-nano
QA_RESOLVER_MODEL=google:gemini-3.1-flash-lite
EMBEDDING_MODEL=openai:text-embedding-3-small

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_JWT_SECRET=
ANSWER_ENCRYPTION_KEY=
ENVIRONMENT=development

# --- Website frontend (web/), exposed client-side — safe to expose per Supabase docs ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
